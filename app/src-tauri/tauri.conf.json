{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meowo",
  "identifier": "com.larrygogo.meowo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1268",
    "beforeDevCommand": "bun ../scripts/prepare-sidecar.mjs && bun run dev",
    "beforeBuildCommand": "bun ../scripts/prepare-sidecar.mjs && bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Meowo",
        "width": 360,
        "height": 440,
        "minWidth": 360,
        "minHeight": 240,
        "transparent": true,
        "decorations": false,
        "maximizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "resizable": true,
        "focus": false,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app"],
    "externalBin": ["binaries/meowo-reporter"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "hardenedRuntime": true,
      "signingIdentity": null
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCQURCRTg1RTBGNzJCNjUKUldSbEsvZmdoYjZ0YTQvWDg4cGI5ZjAxUTZhWVpUVTVBNk4rSFc3UW9JTTE2NmVKMlJUUmg2ZDMK",
      "endpoints": [
        "https://github.com/larrygogo/meowo/releases/latest/download/latest.json"
      ]
    }
  }
}
