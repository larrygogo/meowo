node_modules/
target/
dist/
dev.log
*.db
*.db-wal
*.db-shm
app/src-tauri/gen/
# prepare-sidecar.mjs 生成的 sidecar 产物（构建时按 target triple 重新生成）
app/src-tauri/binaries/
# E2E 构建期由 e2e/run.mjs 临时拷入的 WDIO capability，跑完即删，不应入库
app/src-tauri/capabilities/wdio.json
# WDIO 运行时的日志捕获目录
app/logs/

# macOS 签名材料(私钥/证书/p12),绝不提交
.signing/

# Claude Code：worktree 工作副本与本地设置覆盖。
# 不整个忽略 .claude/——项目级的 settings.json / skills 是该入库共享的。
.claude/worktrees/
.claude/settings.local.json

# Next.js 误生成的构建输出（本项目用 Vite，此目录只会是误跑 next 的产物）
.next/

# 本地海报/聊天预览导出的临时工具页（半成品草稿；若完善成正式工具应改为提交，
# 与已入库的 scripts/record-demo.mjs 同等对待）
app/chat-preview.html
app/poster.html
app/scripts/export-poster.mjs
app/src/chat-preview.tsx
